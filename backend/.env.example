ENV=development
# Documentación OpenAPI: /docs solo si ENV≠production y EXPOSE_OPENAPI=true
EXPOSE_OPENAPI=true
# Registro en /auth/register (desactivado por defecto en código; pon true en local si usas Register)
PUBLIC_REGISTRATION_ENABLED=true
# POST /bot/webhook responde 503 sin firma si falta
# META_APP_SECRET=
# GET /bot/webhook (verificación Meta): mismo valor que en el panel Meta
# META_VERIFY_TOKEN=
# Desactivar simulador de bot: ENABLE_BOT_MOCK_ENDPOINT=false
ENABLE_BOT_MOCK_ENDPOINT=true
# En producción: ENV=production, SECRET_KEY seguro y ALLOWED_ORIGINS=https://tu-dominio.com
# ALLOWED_ORIGINS=https://app.example.com,http://localhost:5173
DATABASE_URL=
# Si no usas DATABASE_URL, define POSTGRES_PASSWORD en .env (no dejar contraseña en código).
# POSTGRES_PASSWORD=

# JWT: access corto + refresh largo (días)
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Connection pool (DB) ────────────────────────────────────────────────────────
# Tamaños pensados para Postgres tras PgBouncer. Si conectas directo a PG sin pooler,
# baja DB_POOL_SIZE/DB_MAX_OVERFLOW para no agotar `max_connections` de Postgres.
# DB_POOL_SIZE=20
# DB_MAX_OVERFLOW=30
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=1800

# ── Lifecycle (startup) ─────────────────────────────────────────────────────────
# En producción: RUN_STARTUP_MIGRATIONS=False y correr `alembic upgrade head` en deploy.
# RUN_STARTUP_MIGRATIONS=True
# RUN_STARTUP_SEED=True

# ── Observability ───────────────────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_TRACES_SAMPLE_RATE=0.0     # 0.0 = solo errores (gratis); 0.1 = 10% trazas
# LOG_FORMAT=console                # "console" en dev | "json" en prod
# LOG_LEVEL=INFO

# CORS: en desarrollo sin ALLOWED_ORIGINS se usan localhost:5173/3000. En prod define ALLOWED_ORIGINS.

# CSP estricta en producción: configurar en nginx/CDN (no en index.html: rompe Vite en dev).

# WhatsApp multi-tenant: PATCH /organizations/me/whatsapp con el phone_number_id de Meta;
# sin vinculación, los eventos del webhook se omiten (no hay fallback a otra org).
