ENV=development
# Registro en /auth/register (desactivado por defecto en código; pon true en local si usas Register)
PUBLIC_REGISTRATION_ENABLED=true
# META_APP_SECRET obligatorio para POST /bot/webhook en producción
# META_APP_SECRET=
# Desactivar simulador de bot: ENABLE_BOT_MOCK_ENDPOINT=false
ENABLE_BOT_MOCK_ENDPOINT=true
# En producción: ENV=production, SECRET_KEY seguro y ALLOWED_ORIGINS=https://tu-dominio.com
# ALLOWED_ORIGINS=https://app.example.com,http://localhost:5173
DATABASE_URL=
